# DEV-02: Environment variable reference for SONIC AI
# Copy to .env.local and fill in values for your environment.

# Set to 'true' when running inside AI Studio to prevent HMR flickering.
# Only used when webpack bundler is active (not Turbopack).
DISABLE_HMR=false

# Displayed as the build version in the app footer / about screen.
NEXT_PUBLIC_APP_VERSION=

# Comma-separated list of origins allowed for cross-origin audio loading.
# Example: https://my-dev-server.run.app
ALLOWED_DEV_ORIGINS=
